# Local development (the app automatically appends /api to the API origin).
VITE_APP_ENV=local
VITE_API_BASE_URL=http://localhost:8000
VITE_MAIN_FRONTEND_URL=http://localhost:3000
VITE_MARKETPLACE_URL=http://localhost:3002

# Mock data is only used when explicitly enabled.
VITE_USE_MOCK_API=false

# Optional Dutch postcode + house number "Find address" lookup at checkout.
# Disabled by default; the manual address fields always work regardless.
VITE_ADDRESS_LOOKUP_ENABLED=false

# Production values:
# VITE_APP_ENV=production
# VITE_API_BASE_URL=https://api.guidewisey.com
# VITE_MAIN_FRONTEND_URL=https://www.guidewisey.com
# VITE_MARKETPLACE_URL=https://marketplace.guidewisey.com
